<?xml version='1.0' encoding='utf-8'?>

<!--
    etch341 WiX source. Built into per-arch .msi installers via
    cargo-wix in CI on a Windows native-arch runner (see release.yml).
    Replaces cargo-packager's `-f wix` path, which bundles WiX 3.11
    and therefore couldn't pass `-arch arm64` to candle.exe — see
    Cargo.toml's [package.metadata.wix] block for the backstory.

    Hand-written rather than cargo-wix-init-generated so we can:
      * Skip the WixUI_InstallDir flow that needs a license.rtf
      * Set the winget-relevant ARP properties explicitly
      * Pin the UpgradeCode to a value that matches Cargo.toml so
        version-to-version upgrades replace cleanly

    Winget conformance items this file satisfies:
      * InstallScope = perMachine          : HKLM writes, files
                                             under ProgramFiles64
      * ARPINSTALLLOCATION set explicitly  : winget reads this to
                                             find the primary .exe
      * Stable UpgradeCode                 : MajorUpgrade replaces
                                             prior installs cleanly
      * ProductCode = '*'                  : auto-generated per build
      * ARPPRODUCTICON                     : Apps & Features shows
                                             the etch341 icon
      * ARPNOMODIFY / ARPNOREPAIR          : hide buttons we don't
                                             actually support
-->

<!--
    `sys.BUILDARCH` is set by candle.exe's `-arch` flag (passed by
    cargo-wix from the cargo target triple). On x64 and arm64 we
    drop files under `Program Files\etch341\`; on 32-bit hosts —
    which we don't ship for, but cover defensively — we fall back
    to the 32-bit `Program Files` folder.
-->
<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <Product
        Id='*'
        Name='etch341'
        UpgradeCode='A1FC4A94-D7CC-4E33-AED8-691272859196'
        Manufacturer='packetThrower'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Description='etch341: cross-platform CLI/GUI flash programmer for the CH341A'
            Manufacturer='packetThrower'
            InstallerVersion='500'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252'/>

        <!--
            Replace-on-upgrade. `afterInstallInitialize` means the
            new install removes the old one cleanly before files
            land. `DowngradeErrorMessage` fires when the user
            double-clicks an older .msi over a newer install
            (winget itself blocks downgrades; this is for the
            hand-installed path).
        -->
        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of etch341 is already installed. Setup will now exit.'/>

        <Media Id='1' Cabinet='etch341.cab' EmbedCab='yes'/>

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='$(var.PlatformProgramFilesFolder)'>
                <Directory Id='APPLICATIONFOLDER' Name='etch341'>
                    <Component Id='MainExecutable' Guid='*'>
                        <File Id='Etch341Exe'
                            Name='etch341.exe'
                            DiskId='1'
                            Source='$(var.CargoTargetBinDir)\etch341.exe'
                            KeyPath='yes'/>
                    </Component>
                </Directory>
            </Directory>

            <!--
                Start Menu shortcut. winget's executable-discovery
                step also checks .lnk targets in known menu paths;
                pointing one at etch341.exe doubles as a backup
                discovery anchor if the ARP InstallLocation lookup
                ever drifts.
            -->
            <Directory Id='ProgramMenuFolder'>
                <Component Id='StartMenuShortcut' Guid='D34C7C87-77A6-466D-8A61-F18F874BD6D9'>
                    <Shortcut Id='Etch341StartMenuShortcut'
                        Name='etch341'
                        Description='Flash programmer for the CH341A USB SPI/I2C interface'
                        Target='[APPLICATIONFOLDER]etch341.exe'
                        WorkingDirectory='APPLICATIONFOLDER'/>
                    <RegistryValue Root='HKCU'
                        Key='Software\packetThrower\etch341'
                        Name='installed'
                        Type='integer'
                        Value='1'
                        KeyPath='yes'/>
                </Component>
            </Directory>
        </Directory>

        <Feature Id='Main' Title='etch341' Description='etch341 application' Level='1'>
            <ComponentRef Id='MainExecutable'/>
            <ComponentRef Id='StartMenuShortcut'/>
        </Feature>

        <!--
            App icon for Apps and Features. Without ARPPRODUCTICON,
            the listing shows Windows Installer's generic blue
            MSI glyph. Reusing resources/icons/icon.ico (the same
            .ico the embed-resource build script compiles into
            etch341.exe's PE resource section, once that's wired)
            means the Apps & Features icon matches the icon on
            the .exe everywhere else.

            Id MUST end in `.ico` — Windows Installer uses the
            suffix to figure out the resource type. A bare
            `Id='AppIcon'` compiles but produces a corrupted icon
            at install time.
        -->
        <Icon Id='AppIcon.ico' SourceFile='resources/icons/icon.ico'/>
        <Property Id='ARPPRODUCTICON' Value='AppIcon.ico'/>

        <!--
            Winget-relevant ARP properties:
              * ARPINSTALLLOCATION — written to
                HKLM\…\Uninstall\<ProductCode>\InstallLocation. The
                winget validator reads this to find etch341.exe.
              * ARPHELPLINK / ARPURLINFOABOUT — populate "Help" +
                "Product website" links in Apps & Features.
              * ARPNOMODIFY / ARPNOREPAIR — hide buttons we don't
                actually support.
        -->
        <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>
        <Property Id='ARPHELPLINK' Value='https://github.com/packetThrower/etch341'/>
        <Property Id='ARPURLINFOABOUT' Value='https://github.com/packetThrower/etch341'/>
        <Property Id='ARPNOMODIFY' Value='yes'/>
        <Property Id='ARPNOREPAIR' Value='yes'/>

        <!--
            No UIRef. winget runs the .msi with `/quiet`, and
            double-click installs get Windows Installer's built-in
            progress dialog — sufficient for a single-binary app.
            Skipping WixUI_* means we don't need a license.rtf.
        -->
    </Product>

</Wix>
